<mujoco model="anymal_c_navigation_scene">
    <include file="anymal_c.xml"/>

    <option timestep="0.01" iterations="50" solver="Newton" tolerance="1e-10"/>

    <statistic center="0 0 0.5" extent="2"/>

    <visual>
        <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
        <rgba haze="0.15 0.25 0.35 1"/>
        <global azimuth="120" elevation="-20"/>
    </visual>

    <asset>
        <texture type="2d" name="groundplane" builtin="checker" mark="edge" 
                 rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8" 
                 width="300" height="300"/>
        <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
        <material name="target_arrow_mat" rgba="0.95 0.35 0.20 0.90"/>
        <material name="desired_arrow_mat" rgba="0.10 0.75 0.95 0.85"/>
        <material name="robot_arrow_mat" rgba="0.20 0.95 0.20 0.85"/>
    </asset>

    <worldbody>
        <light pos="0 0 1.5" dir="0 0 -1" directional="true" castshadow="false"/>
        
        <geom name="floor" size="0 0 0.05" type="plane" material="groundplane" friction="1 0.005 0.0001"/>

        <!-- Navigation target marker (mocap body updated by environment code) -->
        <body name="target_marker" mocap="true" pos="0 0 0.5">
            <geom type="capsule" fromto="0 0 0 0.45 0 0" size="0.020"
                  contype="0" conaffinity="0" material="target_arrow_mat"/>
            <geom type="sphere" pos="0.50 0 0" size="0.045"
                  contype="0" conaffinity="0" material="target_arrow_mat"/>
        </body>

        <!-- Robot current heading arrow (derived from actual XY velocity direction) -->
        <body name="robot_heading_arrow" mocap="true" pos="0 0 0.8">
            <geom type="capsule" fromto="0 0 0 0.35 0 0" size="0.015"
                  contype="0" conaffinity="0" material="robot_arrow_mat"/>
            <geom type="sphere" pos="0.39 0 0" size="0.030"
                  contype="0" conaffinity="0" material="robot_arrow_mat"/>
        </body>

        <!-- Desired heading arrow (derived from navigation controller command) -->
        <body name="desired_heading_arrow" mocap="true" pos="0 0 0.8">
            <geom type="capsule" fromto="0 0 0 0.35 0 0" size="0.012"
                  contype="0" conaffinity="0" material="desired_arrow_mat"/>
            <geom type="sphere" pos="0.39 0 0" size="0.028"
                  contype="0" conaffinity="0" material="desired_arrow_mat"/>
        </body>
    </worldbody>
    
</mujoco>